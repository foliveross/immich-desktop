{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "shell-immich",
  "description": "Allow spawning Immich CLI and system utilities",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "immich", "cmd": "immich", "args": true },
        { "name": "npx", "cmd": "npx", "args": true },
        { "name": "where", "cmd": "where", "args": true },
        { "name": "netsh", "cmd": "netsh", "args": true },
        { "name": "powershell", "cmd": "powershell", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "immich", "cmd": "immich", "args": true },
        { "name": "npx", "cmd": "npx", "args": true },
        { "name": "where", "cmd": "where", "args": true },
        { "name": "netsh", "cmd": "netsh", "args": true },
        { "name": "powershell", "cmd": "powershell", "args": true }
      ]
    }
  ]
}
