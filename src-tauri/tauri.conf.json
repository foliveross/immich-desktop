{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ImmichDesktop",
  "version": "0.1.0",
  "identifier": "com.immichdesktop.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Immich Desktop",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": true
      }
    },
    "shortDescription": "Windows GUI wrapper for the Immich CLI",
    "longDescription": "Immich Desktop provides a native Windows interface for uploading and syncing photos to your Immich server using the official Immich CLI."
  }
}
